OPENAI_API_KEY=sk-...2
ALPHA_VANTAGE_API_KEY=...
# Alpaca paper trading creds. Wave 1.5 supports 3 separate paper accounts.
# Legacy ALPACA_API_KEY / ALPACA_SECRET_KEY still work — they map to the
# Balanced strategy if ALPACA_API_KEY_BALANCED isn't set.
ALPACA_API_KEY_AGGRESSIVE=...
ALPACA_SECRET_KEY_AGGRESSIVE=...
ALPACA_API_KEY_BALANCED=...
ALPACA_SECRET_KEY_BALANCED=...
ALPACA_API_KEY_CONSERVATIVE=...
ALPACA_SECRET_KEY_CONSERVATIVE=...
DATABASE_URL=postgresql://localhost:5432/stockinvest

# LLM routing and safety controls
# local/cloud keep LLMs as the primary analyst voice. deterministic is the fast rule-based path.
ANALYST_MODE=local
ANALYST_FALLBACK=deterministic
ANALYST_INCLUDE_DETERMINISTIC_BASELINE=true
ANALYST_COMPARISON_LOG_ENABLED=true
ANALYST_COMPARISON_LOG_DIR=logs
ANALYST_MAX_RETRIES=1
REGIME_MODE=local
REGIME_FALLBACK=deterministic
REGIME_MAX_RETRIES=0
LOCAL_PROVIDER=ollama
LOCAL_MODEL=qwen3.6:35b-a3b
LOCAL_LLM_TIMEOUT_SECONDS=240
LOCAL_LLM_NUM_PREDICT=1800
LOCAL_LLM_THINK=false

# Optional llama.cpp backend. Set LOCAL_PROVIDER=llama_cpp and point this at a .gguf file.
LLAMA_CPP_MODEL_PATH=
LLAMA_CPP_CHAT_FORMAT=
LLAMA_CPP_N_CTX=8192
LLAMA_CPP_N_GPU_LAYERS=-1
LLAMA_CPP_N_THREADS=0
LLAMA_CPP_VERBOSE=false

ANALYSTS_PARALLEL_WORKERS=1
CLOUD_LLM_TIMEOUT_SECONDS=180
RESEARCHERS_PARALLEL=true
TICKER_TIMEOUT_SECONDS=480

# Wave 2 D1: IBKR options provider. Default is `ibkr` — set to `yfinance`
# to disable IBKR routing (CI / dev boxes without IB Gateway running).
# Per plan A2, this is the *preferred* provider; per-ticker fallback to
# yfinance happens automatically on IBKR failure.
OPTIONS_DATA_PROVIDER=ibkr
IBKR_HOST=127.0.0.1
# 4002=paper Gateway, 4001=live Gateway, 7497=paper TWS, 7496=live TWS
IBKR_PORT=4002
# 1=live (needs equity sub), 3=delayed-with-live-override, 4=delayed-frozen
IBKR_MARKET_DATA_TYPE=3

# Greeks computation:
#   local_bs      = compute via Black-Scholes from OPRA bid/ask (default; no extra sub needed)
#   ibkr_provider = use IBKR's modelGreeks (requires underlying equity data sub)
# Flip to ibkr_provider once your monthly commissions ≥ $30 (equity sub becomes free).
OPTIONS_GREEKS_STRATEGY=local_bs
RISK_FREE_RATE=0.045
